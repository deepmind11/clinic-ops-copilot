# ClinicOps Copilot — copy to .env and fill in your values
# cp .env.example .env

# Required — get a key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# LLM model (default: anthropic/claude-sonnet-4.5)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Postgres — matches docker-compose.yml defaults
DATABASE_URL=postgresql://clinicops:clinicops_dev@localhost:5433/clinic_ops
