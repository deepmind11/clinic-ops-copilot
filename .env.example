# ClinicOps Copilot — copy to .env and fill in your values
# cp .env.example .env

# ---------------------------------------------------------------------------
# LLM provider — any OpenAI-compatible endpoint
# ---------------------------------------------------------------------------

# Option A: OpenRouter (access 100+ models with one key — https://openrouter.ai)
LLM_API_KEY=sk-or-v1-...
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4.5

# Option B: OpenAI directly
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Option C: Ollama (local, no API key required)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Postgres — matches docker-compose.yml defaults
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://clinicops:clinicops_dev@localhost:5433/clinic_ops
